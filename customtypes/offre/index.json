{
  "format": "page",
  "id": "offre",
  "label": "Offre",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": { "label": "UID" }
      },
      "title": {
        "type": "Text",
        "config": { "label": "Titre du poste" }
      },
      "date": {
        "type": "Date",
        "config": { "label": "Date de publication" }
      },
      "technos": {
        "type": "Group",
        "config": {
          "label": "Technologies",
          "repeat": true,
          "fields": {
            "techno": {
              "type": "Link",
              "config": {
                "label": "Techno",
                "select": "document",
                "customtypes": ["techno"]
              }
            }
          }
        }
      },
      "emails": {
        "type": "Group",
        "config": {
          "label": "Emails administrateurs",
          "repeat": true,
          "fields": {
            "email": {
              "type": "Text",
              "config": { "label": "Email" }
            }
          }
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "text_slice": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "type": "Text",
        "config": { "label": "Meta Title" }
      },
      "meta_description": {
        "type": "Text",
        "config": { "label": "Meta Description" }
      },
      "meta_image": {
        "type": "Image",
        "config": {
          "label": "Meta Image",
          "constraint": { "width": 2400, "height": 1260 }
        }
      }
    }
  }
}
