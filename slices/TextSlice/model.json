{
  "id": "text_slice",
  "type": "SharedSlice",
  "name": "TextSlice",
  "description": "Bloc de texte pour le corps d'une offre.",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Default",
      "imageUrl": "",
      "primary": {
        "title": {
          "type": "Text",
          "config": {
            "label": "Titre",
            "placeholder": "Titre de la section"
          }
        },
        "text": {
          "type": "StructuredText",
          "config": {
            "label": "Texte",
            "placeholder": "Description de l'offre...",
            "allowTargetBlank": true,
            "multi": "paragraph,heading2,heading3,strong,em,hyperlink,list-item,o-list-item"
          }
        }
      },
      "items": {}
    }
  ]
}
